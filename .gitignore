# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/

# 模型权重
*.pt
*.bin
*.safetensors
*.gguf

# 数据/缓存/输出
.cache/
# data/ 下:忽略数据 blob(图像/jsonl/csv/parquet/子目录),但保留 .py 准备脚本
/data/*
!/data/*.py
checkpoints/
runs/
outputs/
*.log

# 本地模型缓存 (605MB CLIP + potential future weights)
weights/

# 第三方 vendored 依赖 (llama.cpp 源码 + build, 319MB; 通过 docs 记录构建步骤而非入库)
thirdparty/

# ONNX 导出产物 (大文件, 由 benchmark/export_onnx.py 生成)
onnx/
*.onnx
*.onnx.data

# 训练日志保留 (小文件, 作为进度凭证提交)
!logs/
!logs/*.log

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# 试错日志归档 (移出跟踪, 仅本地保留)
logs/_archive/

# 私有文档 (面试话术/简历对齐/agent 交接, 本地保留不公开)
docs/_private/

# 废弃数据集 prep 脚本 (本地留存不公开)
data/_archive/

# ONNX 导出工具 (备用部署路, 本地留存)
benchmark/export_onnx.py
onnx/
